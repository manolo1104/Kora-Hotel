# Variables públicas del sitio (NEXT_PUBLIC_*).
# Todas terminan en el navegador, así que no son secretas: se versionan en git
# y Vercel las toma automáticamente al desplegar.
#
# Para sobrescribir un valor solo en tu computadora, ponlo en .env.local
# (ese archivo NO se sube a git).

# A dónde llegan los leads del formulario de contacto (cuenta de Formspree)
NEXT_PUBLIC_FORMSPREE_URL=https://formspree.io/f/maqklkjd

# Número de WhatsApp (formato internacional, sin "+" ni espacios)
NEXT_PUBLIC_WHATSAPP_NUMBER=524891251458

# Google Analytics: pegar el ID (G-XXXXXXXXXX) cuando esté listo el dominio
NEXT_PUBLIC_GA_ID=

# URL pública del sitio. Cuando korahotel.mx esté en vivo, cambiar esta línea
# a https://korahotel.mx
NEXT_PUBLIC_SITE_URL=https://kora-hotel.vercel.app
